# Development Profile Template
# Copy this file to application-dev.yml and fill in your values

spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://localhost:3306/demand_system?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
  data:
    redis:
      host: localhost
      port: 6379
      password: YOUR_REDIS_PASSWORD
      database: 0
  rabbitmq:
    host: localhost
    port: 5672
    username: YOUR_RABBITMQ_USERNAME
    password: YOUR_RABBITMQ_PASSWORD
    virtual-host: /

jwt:
  secret: YOUR_JWT_SECRET_KEY_MUST_BE_AT_LEAST_256_BITS_LONG
  access-token-expiration: 7200000
  refresh-token-expiration: 604800000

minio:
  endpoint: http://localhost:9000
  access-key: YOUR_MINIO_ACCESS_KEY
  secret-key: YOUR_MINIO_SECRET_KEY
  bucket-name: demand-system
